\name{print.xtpcmg}
\alias{print.xtpcmg}
\title{Print Method for xtpcmg Objects}
\description{Prints a formatted summary of an \code{"xtpcmg"} result.}
\usage{
\method{print}{xtpcmg}(x, \dots)
}
\arguments{
  \item{x}{An object of class \code{"xtpcmg"}.}
  \item{\dots}{Additional arguments (ignored).}
}
\value{Invisibly returns \code{x}.}
